WALLET_CONNECT_PROJECT_ID=b7b3d81af86feb2af54461f26b665ee4

# ── Mock environment (local development only, never set in production) ────────
# Set MOCK_WALLET=true to enable mock mode in `pnpm dev`:
#   • wagmi mock connector with 4 fixture accounts (Alice/Bob/Carol/Dave)
#   • In-process mock JSON-RPC server on MOCK_RPC_PORT (default 8545)
#   • In-process mock GraphQL fixture server on MOCK_GRAPHQL_PORT (default 4321)
# Tests do **not** read these — they spawn a fresh stack on ephemeral ports
# via @subsquid/mock-stack, no env vars required.
MOCK_WALLET=
MOCK_RPC_PORT=8545
MOCK_GRAPHQL_PORT=4321

TESTNET_WORKERS_SQUID_API_URL=https://subsquid.squids.live/sqd-workers-tethys@v1/api/graphql
MAINNET_WORKERS_SQUID_API_URL=https://subsquid.squids.live/sqd-workers-mainnet@v1/api/graphql
TESTNET_GATEWAYS_SQUID_API_URL=https://subsquid.squids.live/sqd-gateways-tethys@v1/api/graphql
MAINNET_GATEWAYS_SQUID_API_URL=https://subsquid.squids.live/sqd-gateways-mainnet@v1/api/graphql
TESTNET_TOKEN_SQUID_API_URL=https://subsquid.squids.live/sqd-token-tethys@v1/api/graphql
MAINNET_TOKEN_SQUID_API_URL=https://subsquid.squids.live/sqd-token-mainnet@v1/api/graphql
RPC_URL=
NETWORK=mainnet
SERVER_PORT=3001
SENTRY_DSN=
