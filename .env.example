WALLET_CONNECT_PROJECT_ID=b7b3d81af86feb2af54461f26b665ee4
# ── Mock environment (local development only, never set in production) ────────
# Set MOCK_WALLET=true to enable the full mock stack:
#   • wagmi mock connector with 4 fixture accounts (Alice/Bob/Carol/Dave)
#   • In-process mock JSON-RPC server (EIP-1193) for blockchain reads/writes
#   • In-process mock GraphQL fixture server replacing the real Squid APIs
# Account switching uses the standard disconnect → connect → select flow.
# All state (balances, transactions) resets when the dev server restarts.
MOCK_WALLET=
MOCK_RPC_PORT=8545
MOCK_GRAPHQL_PORT=4321
