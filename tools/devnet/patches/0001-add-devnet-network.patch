+/**
+ * Shape of `DEVNET_DEPLOYMENTS_PATH` JSON.
+ *
+ * Either flat (`{ "SQD": "0x...", ... }` — the format `mock-stack` writes
+ * to `.deployments.json`) or structured (`{ "contracts": { "SQD": { "address",
+ * "from" } }, ... }`). The flat shape is the common case; the structured
+ * shape is supported for parity with how mainnet/tethys are described above.
+ */
+type DevnetDeploymentsFile =
+  | Record<string, string>
+  | {
+      contracts?: Record<string, string | { address: string; from?: number; to?: number }>
+      defaultRouterContracts?: Partial<NetworkConfig['defaultRouterContracts']>
+      range?: { from?: number; to?: number }
+      epochsStart?: number
+    }
+
+function makeContract(address: string, from = 0, to?: number): ContractConfig {
+  return { address: address.toLowerCase(), range: { from, to } }
+}
+
+function buildDevnetConfig(): NetworkConfig {
+  const path = process.env.DEVNET_DEPLOYMENTS_PATH ?? '/devnet/deployments.json'
+  const raw = JSON.parse(fs.readFileSync(path, 'utf-8')) as DevnetDeploymentsFile
+
+  const flat = (raw as { contracts?: unknown }).contracts == null
+  const contracts: Record<string, { address: string; from?: number; to?: number }> = {}
+  const defaultRouterContracts: Partial<NetworkConfig['defaultRouterContracts']> = {}
+  let rangeFrom = 0
+  let epochsStart = 0
+
+  if (flat) {
+    const flatRaw = raw as Record<string, string>
+    const ZERO = '0x0000000000000000000000000000000000000000'
+    contracts.SQD = { address: flatRaw.SQD ?? ZERO }
+    contracts.Router = { address: flatRaw.ROUTER ?? ZERO }
+    contracts.RewardsDistribution = { address: flatRaw.REWARD_DISTRIBUTION ?? ZERO }
+    contracts.GatewayRegistry = { address: flatRaw.GATEWAY_REGISTRATION ?? ZERO }
+    contracts.Multicall3 = { address: flatRaw.MULTICALL ?? ZERO }
+    contracts.SoftCap = { address: flatRaw.SOFT_CAP ?? ZERO }
+    contracts.VestingFactory = { address: flatRaw.VESTING_FACTORY ?? ZERO }
+    contracts.TemporaryHoldingFactory = { address: flatRaw.TEMPORARY_HOLDING_FACTORY ?? ZERO }
+    contracts.PortalPoolFactory = { address: flatRaw.PORTAL_POOL_FACTORY ?? ZERO }
+    defaultRouterContracts.networkController = flatRaw.NETWORK_CONTROLLER ?? ZERO
+    defaultRouterContracts.rewardCalculation = flatRaw.REWARD_CALCULATION ?? ZERO
+    defaultRouterContracts.rewardTreasury = flatRaw.REWARD_TREASURY ?? ZERO
+    defaultRouterContracts.workerRegistration = flatRaw.WORKER_REGISTRATION ?? ZERO
+    defaultRouterContracts.staking = flatRaw.STAKING ?? ZERO
+  } else {
+    const structured = raw as Exclude<DevnetDeploymentsFile, Record<string, string>>
+    for (const [key, value] of Object.entries(structured.contracts ?? {})) {
+      if (typeof value === 'string') contracts[key] = { address: value }
+      else contracts[key] = { address: value.address, from: value.from, to: value.to }
+    }
+    Object.assign(defaultRouterContracts, structured.defaultRouterContracts ?? {})
+    rangeFrom = structured.range?.from ?? 0
+    epochsStart = structured.epochsStart ?? 0
+  }
+
+  const need = [
+    'SQD',
+    'Router',
+    'RewardsDistribution',
+    'GatewayRegistry',
+    'Multicall3',
+    'SoftCap',
+    'VestingFactory',
+    'TemporaryHoldingFactory',
+    'PortalPoolFactory',
+  ] as const
+  for (const k of need) {
+    if (!contracts[k]) {
