{
  "name": "@subsquid/subsquid-web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:client": "turbo build --filter=@subsquid/client",
    "build:server": "turbo build --filter=@subsquid/server",
    "build:common": "turbo build --filter=@subsquid/common",
    "start:client": "yarn workspace @subsquid/client start",
    "start:server": "yarn workspace @subsquid/server start",
    "preview": "yarn workspace @subsquid/client preview",
    "analyze": "yarn workspace @subsquid/client analyze",
    "tsc": "turbo tsc",
    "lint": "biome check packages --fix",
    "codegen:graphql": "npx graphql-codegen --config packages/server/graphql.config.ts",
    "codegen:wagmi": "yarn workspace @subsquid/client codegen:wagmi",
    "codegen": "yarn codegen:graphql && yarn codegen:wagmi",
    "upg": "yarn upgrade-interactive"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@graphql-codegen/cli": "^6.0.1",
    "@graphql-codegen/client-preset": "^5.2.2",
    "dotenv": "^17.2.3",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.1.1"
}
