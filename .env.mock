# ── Mock environment ──────────────────────────────────────────────────────────
# Loaded by `pnpm dev:mock`. Mirrors the shape of `.env.example` — values
# pointed at the in-process mock GraphQL fixture server (4321) and the
# in-process mock JSON-RPC server (8545). No special MOCK_* flags: the
# `dev:mock` script + `main.mock.ts` entrypoint pick the mock paths
# explicitly.
WALLET_CONNECT_PROJECT_ID=

TESTNET_WORKERS_SQUID_API_URL=http://localhost:4321/graphql
MAINNET_WORKERS_SQUID_API_URL=http://localhost:4321/graphql
TESTNET_GATEWAYS_SQUID_API_URL=http://localhost:4321/graphql
MAINNET_GATEWAYS_SQUID_API_URL=http://localhost:4321/graphql
TESTNET_TOKEN_SQUID_API_URL=http://localhost:4321/graphql
MAINNET_TOKEN_SQUID_API_URL=http://localhost:4321/graphql

ARBITRUM_ONE_RPC_URL=http://localhost:8545
NETWORK=mainnet
SERVER_PORT=3001
SENTRY_DSN=
